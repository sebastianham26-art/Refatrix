# Refatrix API 환경설정 예시 — 복사해서 .env 로 사용
# 관리형 호스팅(Railway/Render)에서는 대시보드의 환경변수에 동일하게 입력

# PostgreSQL 접속 문자열 (호스팅에서 자동 제공되는 경우가 많음)
DATABASE_URL=postgres://user:password@host:5432/refatrix

# 로그인 토큰 서명 비밀키 — 길고 무작위한 값으로 교체 (절대 공개 금지)
JWT_SECRET=please_change_to_a_long_random_secret

# 서버 포트 (호스팅이 PORT 를 주입하기도 함)
PORT=3000

# 토큰 유효기간
TOKEN_TTL=12h
